:80 {
	root * /srv

	encode zstd gzip

	try_files {path} {path}.html {path}/ /index.html

	file_server

	@static path /_next/static/*
	header @static Cache-Control "public, max-age=31536000, immutable"

	handle_errors {
		@404 expression `{err.status_code} == 404`
		handle @404 {
			rewrite * /404.html
			file_server
		}
	}
}
