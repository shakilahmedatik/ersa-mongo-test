{
  "name": "ersa-chat",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "turbo run lint lint:root",
    "lint:root": "biome check biome.json package.json tsconfig.base.json turbo.json",
    "format": "turbo run format format:root",
    "format:root": "biome format --write biome.json package.json tsconfig.base.json turbo.json",
    "check": "turbo run check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "turbo": "^2.8.21"
  }
}
